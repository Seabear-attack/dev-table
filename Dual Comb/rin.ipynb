   "source": [
    "from numpy import log10\n",
    "electrical_noise_dBm = -100\n",
    "rbw = 1e5\n",
    "v_dc = 1\n",
    "resistance = 50\n",
    "\n",
    "rin_dBc = electrical_noise_dBm  + 10 * log10 (resistance/(1000 * v_dc**2 * rbw))\n",
    "print(f'RIN = {rin_dBc:.0f} dBc/Hz')"
   ]
  }
